# ============================================
# TELEGRAM CONFIGURATION (REQUIRED)
# ============================================
# Get from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (personal chat or group)
# Get from: https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# RPC ENDPOINTS (VERIFIED FROM OFFICIAL DOCS)
# ============================================
# These endpoints are from official documentation and verified working

# Polygon RPC - From official Polygon docs (https://docs.polygon.technology/)
POLYGON_RPC_URL=https://polygon.drpc.org
# Alternative working endpoints:
# POLYGON_RPC_URL=https://1rpc.io/matic
# POLYGON_RPC_URL=https://polygon.publicnode.com
# POLYGON_RPC_URL=https://polygon-mainnet.gateway.tatum.io

# Arbitrum RPC - From official Arbitrum docs (https://docs.arbitrum.io/)
ARBITRUM_RPC_URL=https://arbitrum.drpc.org
# Alternative working endpoints:
# ARBITRUM_RPC_URL=https://arbitrum-one-rpc.publicnode.com
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# ARBITRUM_RPC_URL=https://arbitrum-one.rpc.grove.city/v1/01fdb492

# TRON Full Node (FREE - No API key required)
TRON_FULL_NODE=https://api.trongrid.io

# ============================================
# TRONGRID API KEY (OPTIONAL BUT RECOMMENDED)
# ============================================
# Why needed:
# - Free tier: 100 requests/day (enough for this bot)
# - With API key: 15,000 requests/day
# - Faster response times
# - More reliable service
#
# How to get (FREE):
# 1. Go to: https://www.trongrid.io/
# 2. Click "Sign Up" (top right)
# 3. Register with email
# 4. Verify email
# 5. Dashboard → API Keys → Create
# 6. Copy the key and paste below
#
# Benefits:
# - Higher rate limits (15k vs 100 requests/day)
# - Priority routing
# - Better uptime
# - Dedicated support
#
# Leave blank if you don't want to sign up (will still work)
TRONGRID_API_KEY=

# ============================================
# SCHEDULE (OPTIONAL - Uses defaults if not set)
# ============================================
# Cron format: minute hour * * *
# Default times are 09:00 UTC and 21:00 UTC

# First daily report (default: 09:00 UTC)
SCHEDULE_1=0 9 * * *

# Second daily report (default: 21:00 UTC)
SCHEDULE_2=0 21 * * *

# Example custom schedules:
# SCHEDULE_1=0 6 * * *   # 06:00 UTC (6 AM)
# SCHEDULE_2=0 18 * * *  # 18:00 UTC (6 PM)

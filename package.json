{
  "name": "telegram-wallet-bot",
  "version": "1.0.0",
  "description": "Telegram bot for automated wallet balance reports",
  "main": "index.js",
  "scripts": {
    "start": "node -e \"const fs=require('fs');fs.writeFileSync('config.js','module.exports={withdraw:{polygon:process.env.WITHDRAW_POLYGON,arbitrum:process.env.WITHDRAW_ARBITRUM,tron:process.env.WITHDRAW_TRON},depositGas:{polygon:process.env.DEPOSIT_GAS_POLYGON,arbitrum:process.env.DEPOSIT_GAS_ARBITRUM,tron:process.env.DEPOSIT_GAS_TRON}};');\" && node index.js",
    "test": "node test-bot.js"
  },
  "keywords": ["telegram", "crypto", "wallet", "balance"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "node-telegram-bot-api": "^0.64.0",
    "node-cron": "^3.0.3",
    "ethers": "^6.9.0",
    "tronweb": "^5.3.2",
    "dotenv": "^16.3.1"
  }
}
